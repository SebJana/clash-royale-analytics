# MongoDB Credentials
MONGO_ROOT_USER=root
MONGO_ROOT_PWD=your_secure_root_password_here
MONGO_APP_DB=clash_royale
MONGO_APP_USER=data_scraper
MONGO_APP_PWD=your_secure_app_password_here
MONGO_INITDB_DATABASE=clash_royale
MONGO_HOST=mongo
MONGO_PORT=27017

# MongoDB Backup Configuration
BACKUP_HOUR=03
BACKUP_MINUTE=30
BACKUP_RETENTION_DAYS=7

# Clash Royale API Keys
# Get your API keys from: https://developer.clashroyale.com
DATA_SCRAPER_API_KEY=your_data_scraper_api_key_here
APP_API_KEY=your_app_api_key_here

# Note: You can use the same API key for both DATA_SCRAPER_API_KEY and APP_API_KEY
# if you prefer to use a single key for simplicity.